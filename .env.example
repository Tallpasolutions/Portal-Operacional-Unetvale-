# ===== App (configure estas variáveis na Vercel: Settings -> Environment Variables) =====

# Supabase -> Project Settings -> API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Use a chave service_role (NUNCA exponha no front; o Flask usa só no servidor)
SUPABASE_SERVICE_KEY=eyJhbGciOi...service_role...

# Assina o cookie de sessão (stateless, ok p/ serverless). Gere um valor aleatório longo:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=troque-por-uma-string-aleatoria-longa

# Token compartilhado com o coletor (opcional, se usar o endpoint /api/ingest)
INGEST_TOKEN=troque-por-um-token-secreto
